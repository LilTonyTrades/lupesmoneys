{
  "name": "openclaw-books",
  "version": "1.0.0",
  "description": "OpenClaw Books — Schedule C Bookkeeping for Self-Employed",
  "author": "OpenClaw",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "gen-icon": "node scripts/gen-icon.js",
    "electron:build": "npm run build && node scripts/gen-icon.js && electron-builder --win",
    "electron:build:publish": "npm run build && node scripts/gen-icon.js && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.4",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "jimp": "^0.22.12",
    "png-to-ico": "^2.1.8",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.openclaw.books",
    "productName": "OpenClaw Books",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/",
        "to": "public/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "publisherName": "LilTonyTrades"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenClaw Books",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "LilTonyTrades",
      "repo": "lupesmoneys"
    }
  }
}
